# Contact form (Resend) — copy to .env.local and fill in.
# Create an API key at https://resend.com/api-keys
RESEND_API_KEY=

# Optional overrides:
# Where enquiries are delivered (default: info@cymrai.co.uk)
# CONTACT_TO=info@cymrai.co.uk
# Verified sender. Until cymrai.co.uk is verified at https://resend.com/domains,
# the default onboarding@resend.dev sender only delivers to the email address
# that owns the Resend account.
# CONTACT_FROM=Cymrai Website <enquiries@cymrai.co.uk>
